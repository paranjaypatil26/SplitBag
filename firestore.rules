rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Room documents ────────────────────────────────────────────────────
    match /rooms/{roomCode} {

      // Anyone can read a room (needed to validate room codes on join)
      allow read: if true;

      // Only authenticated users can create a room
      allow create: if request.auth != null
        && request.resource.data.captainUid == request.auth.uid;

      // Only the Captain can update room-level status fields
      allow update: if request.auth != null
        && (
          // Captain updating status, expiry, ordering fields
          resource.data.captainUid == request.auth.uid
          // OR: any authenticated user can increment memberCount & totalCartValue
          || (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['memberCount', 'totalCartValue'])
          )
        );

      // ─── Item submissions subcollection ────────────────────────────────
      match /items/{itemId} {
        // Anyone in the room can read items
        allow read: if true;

        // Members can create their own items
        allow create: if request.auth != null
          && request.resource.data.memberUid == request.auth.uid;

        // Members can update only their own items; Captain can update status on any
        allow update: if request.auth != null
          && (
            resource.data.memberUid == request.auth.uid
            || get(/databases/$(database)/documents/rooms/$(roomCode)).data.captainUid == request.auth.uid
          );

        allow delete: if false;
      }

      // ─── Payments subcollection ─────────────────────────────────────────
      match /payments/{memberUid} {
        // Captain and the member themselves can read/write payment status
        allow read: if request.auth != null;

        allow write: if request.auth != null
          && (
            request.auth.uid == memberUid
            || get(/databases/$(database)/documents/rooms/$(roomCode)).data.captainUid == request.auth.uid
          );
      }
    }
  }
}
